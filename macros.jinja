<!-- Script JS -->

{% macro script(path) %}
<script src="/public/js/{{ path }}"></script>
{% endmacro %}

<!-- Vidéo YouTube -->

{% macro yvideo(link) %}
<iframe 
    width="560" 
    height="315" 
    src="https://www.youtube.com/embed/{{ link }}" 
    title="YouTube video player" 
    frameborder="0" 
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
    referrerpolicy="strict-origin-when-cross-origin" 
    allowfullscreen>
</iframe>
{% endmacro %}

<!-- Liste de liens -->

{% macro links(data, path, title) %}
<h2>{{ title }}</h2>

<ul>
    {% for link in data[path] %}
    <li><a href="{{ path }}/{{ link.href }}.html" target="_blank">{{ link.title }}</a></li>
    {% endfor %}
</ul>
{% endmacro %}

<!-- Titres (H2) -->

{% macro header(id, title) %}
<h2 id="{{ id }}"><a href="#{{ id }}">{{ title }}</a></h2>
{% endmacro %}

<!-- Ancres -->

{% macro anchor(id, type = "*") %}
<div id="{{ id }}">
    <a href="#{{ id }}">
    {% if type == "=" %}
    ===
    {% else %}
    ***
    {% endif %}
    </a>
</div>
{% endmacro %}

<!-- Lien de retour vers le haut -->

{% macro return_link(id = "") %}
<p><a href="#{{ id }}" class="bleu">Retour en haut</a></p>
{% endmacro %}

<!-- Lien simple -->

{% macro link(href, content) %}
<a href="{{ href }}" class="bleu" target="_blank">{{ content }}</a>
{% endmacro %}

<!-- Bouton radio (simple) -->

{% macro radio_btn(value, name, id) %}
<input type="radio" name="{{ name }}" id="{{ id }}" />
<label for="{{ id }}">{{ value }}</label>
{% endmacro %}

<!-- Boutons radios => Grains -->

{% macro grains(type, name) %}
    {% if type == "trio" %}
        {% set list = range(0, 4) %}
    {% elif type == "rondes" %}
        {% set list = range(1, 6) %}
    {% elif type == "septaine" %}
        {% set list = [0, 2, 4, 6, 7] %}
    {% elif type == "dizaine" %}
        {% set list = range(0, 11, 2) %}
    {% elif type == "anges" %}
        {% set list = ["-", "St Michel", "St Gabriel", "St Raphaël", "Ange gardien"] %}
    {% else %}
        {% set list = ["-", "foi", "espérance", "charité"] %}
    {% endif %}

    <p>
    {% for nb in list %}
        {% set id = name + "_" + loop.index | string %}

        {{ radio_btn(nb, name, id) }}
    {% endfor %}
    </p>
{% endmacro %}
