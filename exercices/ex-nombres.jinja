    <p>5 8 9 3 2 4 0</p>

    <h2>Ex Lecture</h2>

    {% include spath + "st-esprit.jinja" %}

    <h2>Ex Chants Grégoriens</h2>

    <p>{{ mc.link("Pater Noster", vroot + "uxuSG19wuss") }}</p>

    <p>{{ mc.link("Gloria Patri", vroot + "sLEKQQfqrRk") }}</p>

    <p>{{ mc.link("Ave Maria (Araméen)", vroot + "RZopVZmYMJw") }}</p>

