{% extends "layouts/base.jinja" %}

{% set title = "Exercice des Nombres" %}

{% set spath = "prieres/special/" %}

{% block content %}
<div class="centre">
    <h2>Exercice des nombres</h2>

    <p>A répéter à haute voix et séparément</p>

    <h3>Soin du corps</h3>

    <p>9 1 8 7 9 4 8 1 8 1</p>

    <h3>Attirer une bonne santé</h3>

    <p>8 0 8 4 5 7 0 0 9</p>

    <h3>Améliorer sa mémoire</h3>

    <p>5 8 9 3 2 4 0</p>

    <h3>Attirer la chance</h3>

    <p>2 0 1 7 1 3 3</p>

    <h2>Ex Affirmations</h2>

    {% for nb in range(1, 8) %}
        <p>
            <input type="checkbox" name="fois" id="a_{{ nb }}">
            <label for="a_{{ nb }}">{{ nb }})</label>
        </p>

        <p>"Si Jésus me libère, je serai vraiment libre."</p>

        {% include spath + "ex-bref.jinja" %}

        {% if not loop.last %}<hr />{% endif %}
    {% endfor %}

    <h2>Ex Chants Grégoriens</h2>

    <h3>Pater Noster</h3>

    {{ mc.audio("pater-noster.mp3") }}

    <h3>Gloria Patri</h3>

    {{ mc.audio("gloria-patri.mp3") }}

    <h2>Ex Respiration</h2>

    <p>Bien suivre selon les indications avec le symbôle et le coeur :</p>

    {{ mc.yvideo("sGuuuE_t2Lw?si=f1EgnYmX3HtRCYmh") }}

    <h2>Ex Subliminal</h2>

    {{ mc.yvideo("AQK6kBI52bo?si=-VExqPGO93bXUJg_") }}

    <h2>Vidéo Bonus</h2>

    {{ mc.yvideo("RZopVZmYMJw?si=vCdF3xd4SM8sPX5i") }}
</div>
{% endblock %}
