{% extends "layouts/base.jinja" %}

{% set title = "Exercice des Nombres" %}

{% set spath = "prieres/saints/" %}

{% set vroot = "https://www.youtube.com/watch?v=" %}

{% block content %}
<audio loop autoplay id="subliminal">
    <source src="/public/music/subliminal.mp3" type="audio/mp3" />
