{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set spath = "prieres/special/" %}

{% set rpath = "chapelets/rosaire/" %}

{% set title = "Chapelet pour les défunts" %}

{% block content %}
<p>{{ mc.cb_version() }}</p>

<p>
Le <b>chapelet</b> basé sur le <b>rosaire</b> traditionnel s'inspire de l'application 
{{ mc.link("https://rosario.app/", "Rosario") }} par
{{ mc.link("https://hozana.org/", "Hozana") }}.
</p>

<p>Les {{ mc.link("/prieres/lit-lorette.html", "Litanies de Lorette") }} sont complémentaires.</p>

<hr />

{% include bpath + "signe-croix.jinja" %}

<!-- Base -->

{{ mc.anchor("base", "=") }}

{% include rpath + "rs-base.jinja" %}

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

{% include rpath + "rs-mysteres.jinja" %}

<p id="clausule" class="invisible"></p>

{% include spath + "ex-defunts.jinja" %}

{{ mc.anchor("coeur") }}

<p>Doux Cœur de Marie, Soyez mon salut.</p>

{{ mc.grains("cdizaine", "dz_grains") }}

{{ mc.return_link("mysteres") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer") }}

<!-- Scripts -->

{% include rpath + "rs-scripts.jinja" %}

{% endblock %}