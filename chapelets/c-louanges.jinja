{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set vpath = "prieres/versets/" %}

{% set lpath = "chapelets/louanges/" %}
{% set rpath = "chapelets/rosaire/" %}

{% set title = "C-Louanges" %}

{% block content %}
<h1>C-Louanges</h1>

<p>
Le chapelet est basé sur la méthode de <b>La Bonne Nouvelle</b> et décrite sur le site de 
{{ mc.link("https://www.mariereine.com/le-chapelet-de-louange/", "Marie Reine") }}.
</p>

<hr />

{% include bpath + "signe-croix.jinja" %}

<!-- Base -->

{{ mc.anchor("base", "=") }}

{% include rpath + "rs-base.jinja" %}

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

{% include rpath + "rs-choix.jinja" %}

{% include rpath + "cl-dizaine.jinja" %}

{{ mc.return_link("mysteres") }}

<!-- Fin -->

{{ mc.anchor("salut_reine", "=") }}

{% include bpath + "salut-reine.jinja" %}

<hr />

{% include bpath + "signe-croix.jinja" %}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}
{{ mc.script("data/d.mysteres.js") }}
{{ mc.script("chapelets/ch-louanges.js") }}

{% endblock %}