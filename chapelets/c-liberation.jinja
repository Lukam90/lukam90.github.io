{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set spath = "prieres/special/" %}

{% set title = "Chapelet de libération" %}

{% block content %}
<p>{{ mc.cb_version() }}</p>

<p>
Ce chapelet reprend sa version d'origine,<br>
à la différence du <b>Je vous salue Marie</b> placé à la fin,<br>
pour des questions de simplicité.
</p>

<p>Le {{ mc.link("/chapelets/chapelet.html", "rosaire") }} reste la dévotion quotidienne de base.</p>

<!-- Base -->

{{ mc.anchor("base", "=") }}

{% include bpath + "signe-croix.jinja" %}

{% include bpath + "credo.jinja" %}

<!-- Rondes -->

{{ mc.anchor("rondes", "=") }}

<p>Je prie à l'intention de <input type="text" id="txt_intention" onkeyup="updateText()" /></p>

<p>
    <select id="sel_rondes" onchange="setBlock()">
        <option>Base</option>
        {% for nb in range(1, 6) %}
        <option>Ronde n°{{ nb }}</option>
        {% endfor %}
    </select>
</p>

<p>
"Si Jésus <span id="prefixe" class="gras">me</span> libère <span id="suffixe" class="gras"></span>,
<span id="pronom" class="gras">je</span> <span id="verbe">serai</span> vraiment libre." (Jean 8, 36)
</p>

<hr />

<ul class="priere">
    <li>Jésus, aie pitié de <span class="gras">moi</span> !<br></li>
    <li>Jésus, guéris<span class="gras">-moi</span> !<br></li>
    <li>Jésus, sauve<span class="gras">-moi</span> !<br></li>
    <li>Jésus, libère<span class="gras">-moi</span> !</li>
</ul>

<div id="trio">
{{ mc.grains("trio", "base_trio") }}
</div>

<div id="dizaines">
{{ mc.grains("cdizaine", "dz_grains") }}
</div>

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include bpath + "ste-marie.jinja" %}

<!-- Réinitialisation -->

{{ mc.anchor("reset", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer", reset = true) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("versions.js") }}

{{ mc.script("chapelets/ch-liberation.js") }}

{% endblock %}