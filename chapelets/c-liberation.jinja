{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set spath = "prieres/special/" %}

{% set lpath = "chapelets/liberation/" %}

{% set title = "C-Liberation" %}

{% block content %}
<h1>Chapelet de libération</h1>

{% include bpath + "signe-croix.jinja" %}

<!-- Base -->

{{ mc.anchor("credo", "=") }}

{% include bpath + "credo.jinja" %}

<!-- Rondes -->

{{ mc.anchor("serie", "=") }}

<p>
    Je prie à l'intention de

    <input type="text" id="intention" />
</p>

<p>
    <select id="sel_rondes" onchange="setSuite();">
        <option>Base</option>
        {% for nb in range(1, 6) %}
        <option>Ronde n°{{ nb }}</option>
        {% endfor %}
    </select>
</p>

<p>"Si le Fils vous libère, vous serez vraiment libres." (Jn 8,36)</p>

<hr />

<ul class="priere">
    <li>Jésus, <b>aie pitié de</b> nous !</li>
    <li>Jésus, <b>guéris</b>-nous !</li>
    <li>Jésus, <b>sauve</b>-nous !</li>
    <li>Jésus, <b>libère</b>-nous !</li>
</ul>

{{ mc.grains("trio", "base_trio") }}

{{ mc.grains("dizaine", "dz_grains") }}

{{ mc.return_link("serie") }}

<!-- Fin -->

{{ mc.anchor("salut_reine", "=") }}

{% include bpath + "salut-reine.jinja" %}

<hr />

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link() }}

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}
{{ mc.script("chapelets/ch-liberation.js") }}

{% endblock %}