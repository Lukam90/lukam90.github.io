{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set opath = "prieres/outros/" %}

{% set lpath = "chapelets/liberation/" %}

{% set title = "C-Liberation" %}

{% set ex_jesus = "\"Si le Fils vous libère, vous serez vraiment libres.\" (Jn 8,36)" %}

{% block content %}
<h1>Chapelet de libération</h1>

<p>
Le chapelet est inspiré de la 2ème méthode décrite dans la 
{{ mc.link("https://boutique.labonnenouvelle.net/revues-voici-ta-mere-/776-chapelet-de-la-liberation-en-telechargement.html", "revue dédiée") }}
<br>de la boutique de la <b>Bonne Nouvelle</b>.
</p>

<hr />

<p>Je prie à l'intention de <input id="intention" type="text" />.</p>

{{ mc.vlatine() }}

{% include bpath + "signe-croix.jinja" %}

<!-- Base -->

{{ mc.anchor("credo", "=") }}

{% include bpath + "credo.jinja" %}

{{ mc.anchor("base") }}

{% include bpath + "notre-pere.jinja" %}

<hr />

<p>{{ ex_jesus }}</p>

{{ mc.grains("trio", "base_trio") }}

<!-- Rondes -->

{{ mc.anchor("rondes", "=") }}

<p>{{ mc.rondes() }}</p>

{% include bpath + "notre-pere.jinja" %}

<hr />

<p>{{ ex_jesus }}</p>

{{ mc.grains("dizaine", "dz_grains") }}

<!-- Fin -->

{{ mc.anchor("salut_reine", "=") }}

{% include bpath + "salut-reine.jinja" %}

{{ mc.anchor("priere_finale") }}

{% include opath + "outro-liberation.jinja" %}

<hr />

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link() }}

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}
{{ mc.script("chapelets/ch-reset.js") }}

{% endblock %}