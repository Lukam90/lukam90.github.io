{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set spath = "prieres/special/" %}

{% set title = "Chapelet de libération des mémoires" %}

{% block content %}
<p>
Ce chapelet est personnel et basé sur la <b>méthode Ho'oponopono</b>.<br>
La <b>prière de Morrnah</b>, revue et simplifiée, se récite sur les gros grains.<br>
Le <b>mantra de base</b> se récite sur les petits grains des dizaines.
</p>

<hr />

<!-- Intention -->

{% include bpath + "signe-croix.jinja" %}

<p>Je prie à l'intention de <input type="text" id="txt_intention" /></p>

<!-- Rondes -->

{{ mc.anchor("rondes", "=") }}

<p>Ronde {{ mc.select("sel_rondes") }}</p>

{% include spath + "ex-hopono.jinja" %}

<hr />

<p>Je te remercie. Je t'aime.</p>

{{ mc.grains("cdizaine", "dz_grains") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer", reset = true) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("versions.js") }}

{{ mc.script("chapelets/ch-liberation.js") }}

{% endblock %}