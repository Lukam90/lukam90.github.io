{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}

{% set rpath = "chapelets/rosaire/" %}

{% set title = "Chapelet pour le salut des âmes" %}

{% block content %}
<p>{{ mc.cb_version() }}</p>

<p>La récitation du chapelet permet de libérer jusqu'à <b>5000 âmes</b> sur <b>4 générations</b>.</p>

<hr />

{% include bpath + "signe-croix.jinja" %}

<!-- Base -->

{{ mc.anchor("base", "=") }}

{% include rpath + "rs-base.jinja" %}

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

{% include rpath + "rs-mysteres.jinja" %}

<p id="clausule" class="invisible"></p>

<p>
Père Eternel,<br>
je vous offre le Sacré-Cœur de Jésus<br>
et le Cœur Immaculé de Marie<br>
pour le salut de nos âmes,<br>
de nos familles<br>
et du monde entier.
</p>

{{ mc.anchor("coeurs") }}

<p>
Sacré-Cœur de Jésus, ayez pitié de nous.<br>
Cœur Immaculé de Marie, priez pour nous.
</p>

{{ mc.grains("cdizaine", "dz_grains") }}

{{ mc.return_link("mysteres") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer") }}

<!-- Scripts -->

{% include rpath + "rs-scripts.jinja" %}

{% endblock %}