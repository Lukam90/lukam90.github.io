{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set spath = "prieres/special/" %}

{% set rpath = "chapelets/rosaire/" %}

{% set title = "Chapelet de libération des âmes" %}

{% block content %}
<p>{{ mc.cb_version() }}</p>

<p>
Les mystères sont repris du {{ mc.link("/chapelets/chapelet.html", "rosaire") }}
restant la dévotion quotidienne de base.
</p>

<hr />

{% include bpath + "signe-croix.jinja" %}

<!-- Base -->

{{ mc.anchor("base", "=") }}

{% include rpath + "rs-base.jinja" %}

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

{% include rpath + "rs-mysteres.jinja" %}

<p id="clausule" class="invisible"></p>

{% include spath + "ex-repos.jinja" %}

{{ mc.anchor("dz_coeurs") }}

<p>Doux Cœur de Marie, Soyez mon salut.</p>

{{ mc.grains("cdizaine", "dz_grains") }}

{{ mc.return_link("mysteres") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer") }}

<!-- Scripts -->

{% include rpath + "rs-scripts.jinja" %}

{% endblock %}