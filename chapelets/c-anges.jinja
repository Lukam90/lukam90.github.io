{% extends "layouts/prieres.jinja" %}

{% set apath = "chapelets/anges/" %}
{% set bpath = "prieres/base/" %}

{% set title = "C-Anges" %}

{% block content %}
<h1>Chapelet de St Michel et des anges</h1>

{% include bpath + "signe-croix.jinja" %}

{{ mc.anchor("base", "=") }}

{% include apath + "an-intro.jinja" %}

{{ mc.anchor("intro_notre_pere") }}

{% include bpath + "notre-pere.jinja" %}

{{ mc.grains("anges", "nbase") }}

{{ mc.anchor("choeurs", "=") }}

{% include apath + "an-choeurs.jinja" %}

{{ mc.anchor("choeur_notre_pere") }}

{% include bpath + "notre-pere.jinja" %}

{{ mc.anchor("choeur_ste_marie") }}

{% include bpath + "ste-marie.jinja" %}

{{ mc.grains("trio", "trio_ste_marie") }}

{{ mc.return_link("choeurs") }}

{{ mc.anchor("antienne", "=") }}

{% include apath + "an-antienne.jinja" %}

{{ mc.anchor("oraison_st_michel") }}

{% include apath + "an-oraison-finale.jinja" %}

<hr />

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link() }}

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}
{{ mc.script("data/d.choeurs.js") }}
{{ mc.script("chapelets/ch-anges.js") }}

{% endblock %}