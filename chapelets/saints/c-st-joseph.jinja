{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set spath = "prieres/saints/" %}

{% set title = "C-St Joseph" %}

{% block content %}
<h1>Rosaire de St Joseph</h1>

<p>Le chapelet est basé sur le <b>rosaire de St Joseph</b>, récité le 1er mercredi de chaque mois.</p>

<hr />

{% include bpath + "signe-croix.jinja" %}

<!-- Base -->

{{ mc.anchor("base", "=") }}

{% include bpath + "credo.jinja" %}

{{ mc.anchor("b_notre_pere") }}

{% include bpath + "notre-pere.jinja" %}

{{ mc.anchor("b_st_joseph") }}

{% include spath + "st-joseph.jinja" %}

{{ mc.grains("trio", "trio_st_joseph") }}

{{ mc.anchor("b_gloire_pere") }}

{% include bpath + "gloire-pere.jinja" %}

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

<p>
    <select id="sel_type" onchange="majChapelet();">
        <option>joyeux</option>
        <option>douloureux</option>
        <option>glorieux</option>
    </select>

    <select id="sel_mysteres" onchange="checkFirst();">
        <option>1. L'annonciation à Joseph</option>
        <option>2. La naissance de Jésus</option>
        <option>3. La circoncision et l’attribution du nom de Jésus</option>
        <option>4. La présentation de Jésus au temple</option>
        <option>5. Le recouvrement de Jésus au temple</option>
    </select>
</p>

{% include bpath + "notre-pere.jinja" %}

{{ mc.anchor("m_st_joseph") }}

{% include spath + "st-joseph.jinja" %}

{{ mc.grains("dizaine", "dz_grains") }}

{{ mc.anchor("m_gloire_pere") }}

{% include bpath + "gloire-pere.jinja" %}

{{ mc.return_link("mysteres") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include spath + "fin-st-joseph.jinja" %}

<hr />

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link() }}

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}

{{ mc.script("chapelets/saints/ch-st-joseph.js") }}

{% endblock %}