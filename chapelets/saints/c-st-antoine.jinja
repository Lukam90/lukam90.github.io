{% extends "layouts/prieres.jinja" %}

{% set title = "C-St-Antoine" %}

{% set bpath = "prieres/base/" %}
{% set ipath = "prieres/intros/" %}
{% set spath = "prieres/saints/" %}

{% block content %}
<h1>Chapelet de St Antoine</h1>

{% include bpath + "signe-croix.jinja" %}

<hr />

<p>
    <select id="sel_ronde" onchange="setIntro();">
        {% for nb in range(1, 14) %}
        <option>Ronde n°{{ nb }}</option>
        {% endfor %}
    </select>
</p>

{% include ipath + "intros-st-antoine.jinja" %}

{{ mc.anchor("notre_pere") }}

{% include bpath + "notre-pere.jinja" %}

{{ mc.anchor("ste_marie") }}

{% include bpath + "ste-marie.jinja" %}

{{ mc.anchor("gloire_pere") }}

{% include bpath + "gloire-pere.jinja" %}

{{ mc.return_link() }}

<hr />

{% include spath + "bref-st-antoine.jinja" %}

<hr />

{% include spath + "fin-st-antoine.jinja" %}

<hr />

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link() }}

{{ mc.script("utils.js") }}
{{ mc.script("chapelets/ch-st-antoine.js") }}

{% endblock %}