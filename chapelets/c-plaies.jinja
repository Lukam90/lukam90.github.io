{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set spath = "prieres/special/" %}

{% set title = "Chapelet des saintes plaies" %}

{% block content %}

{% include bpath + "signe-croix.jinja" %}

<p>Je prie à l'intention de <input type="text" id="txt_intention" /></p>

<!-- Intro -->

{{ mc.anchor("intro", "=") }}

{% include spath + "ex-intro.jinja" %}

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

<p>
    <select id="sel_mysteres" onchange="updateText()">
        <option>1. les mains</option>
        <option>2. les pieds</option>
        <option>3. le dos</option>
        <option>4. la tête</option>
        <option>5. le cœur</option>
        <option>Fin</option>
    </select>
</p>

<p>Père éternel, je t’offre les plaies de notre Seigneur Jésus-Christ pour guérir celles de nos âmes.</p>

<div id="dizaines">
    <hr />

    <p>Mon Jésus, pardon et miséricorde, par les mérites de tes saintes plaies.</p>

    {{ mc.grains("cdizaine", "dz_grains") }}
</div>

<div id="trio">
{{ mc.grains("trio", "fin_trio") }}
</div>

{{ mc.return_link("mysteres") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer", reset = true) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("versions.js") }}

{{ mc.script("chapelets/ch-plaies.js") }}

{% endblock %}