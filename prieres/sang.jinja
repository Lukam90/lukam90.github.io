{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}

{% set title = "Chapelet du précieux sang" %}

{% block content %}

{% include "partials/cb-latin.jinja" %}

{% include bpath + "signe-croix.jinja" %}

<!-- Base -->

{{ mc.anchor("base", "=", "C") }}

{% include bpath + "credo.jinja" %}

{{ mc.anchor("ave", "*", "A") }}

{% include bpath + "ste-marie.jinja" %}

{{ mc.grains("base_trio", ["-", "Père", "Fils", "Saint-Esprit"]) }}

<!-- Mystères -->

{{ mc.anchor("mysteres", "=", "M") }}

<ul class="priere gauche">
    <li>{{ mc.radio_btn("m1", "mysteres", "1. La circoncision") }}</li>
    <li>{{ mc.radio_btn("m2", "mysteres", "2. L'agonie à Gethsémani") }}</li>
    <li>{{ mc.radio_btn("m3", "mysteres", "3. La flagellation") }}</li>
    <li>{{ mc.radio_btn("m4", "mysteres", "4. Le couronnement d'épines") }}</li>
    <li>{{ mc.radio_btn("m5", "mysteres", "5. La montée au Calvaire") }}</li>
    <li>{{ mc.radio_btn("m6", "mysteres", "6. La crucifixion") }}</li>
    <li>{{ mc.radio_btn("m7", "mysteres", "7. Le coup de lance") }}</li>
</ul>

{{ mc.anchor("serie", "*", "P") }}

{% include bpath + "notre-pere.jinja" %}

<div id="premiers">
{{ mc.grains("quintes", range(1, 6)) }}
</div>

<div id="dernier">
{{ mc.grains("fin_trio", range(1, 4)) }}
</div>

<p>
Ô Dieu, venez à mon aide.<br>
Ô Seigneur, hâtez-vous de m’aider ! 
</p>

{{ mc.anchor("suite", "*", "G") }}

{% include bpath + "gloire-pere.jinja" %}

<hr />

<p>
Nous vous supplions, Seigneur,<br>
aidez vos servants que vous avez rachetés<br>
par votre Précieux Sang.
</p>

{{ mc.return_link("mysteres") }}

<!-- Fin -->

{{ mc.anchor("fin", "=", "F") }}

<p>
Père Éternel, je vous offre le plus Précieux Sang de Jésus-Christ<br>
en réparation de mes péchés,<br>
pour les besoins de la sainte Eglise<br>
et pour le soulagement des âmes du purgatoire.
</p>

<hr />

<p>(Signe de croix)</p>

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}

{{ mc.script("chapelets/ch-sang.js") }}

{% endblock %}