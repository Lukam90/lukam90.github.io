{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set rpath = "prieres/rosaire/" %}
{% set spath = "prieres/sang/" %}

{% set title = "Chapelet du précieux sang de Jésus" %}

{% block content %}
<p>La dévotion est complémentaire au {{ mc.link("Saint Rosaire", "/prieres/rosaire.html") }}.</p>

<p>Les {{ mc.link("prières de base", "/prieres/ex-base.html") }} sont listées sur une page dédiée.</p>

<p>Le chapelet a été simplifié en allant à l'essentiel.</p>

<!-- Base -->

{{ mc.anchor("base", "=") }}

<p>(Signe de croix)</p>

{% include spath + "sg-esprit.jinja" %}

{{ mc.anchor("b_prieres") }}

{% include rpath + "rs-base.jinja" %}

{{ mc.anchor("medaille", "=") }}

{% include spath + "sg-medaille.jinja" %}

<!-- Rondes -->

{{ mc.anchor("rondes", "=") }}

{{ mc.grains("dz_rondes", range(1,6)) }}

{% include spath + "sg-intros.jinja" %}

<p class="gras">Notre Père</p>

<p class="gras">Je vous salue Marie</p>

<p>"Précieux Sang de Jésus-Christ, sauve-nous et le monde entier." (x 12)</p>

<p class="gras">Gloire au Père</p>

{{ mc.return_link("rondes") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

<p class="gras">Salut ô Reine</p>

{{ mc.anchor("final") }}

{% include spath + "sg-final.jinja" %}

<hr />

<p>(Signe de croix)</p>

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}

{{ mc.script("chapelets/ch-sang.js") }}

{% endblock %}