{% extends "layouts/prieres.jinja" %}

{% set title = "Psaumes" %}

{% set path = "partials/prieres/" %}

{% block content %}
<h1>Psaumes</h1>

<h2 id="ps23"><a href="#ps23">Psaume 23</a></h2>

{% for content in data["ps-23"] %}
<p class="priere">
    {% set id = "ps23_" + loop.index | string %}
    {% set number = content["number"] %}
    {% set lines = content["lines"] %}

    <a href="#{{ id }}" id="{{ id }}">{{ number }}</a><br>

    {% for line in lines %}
        {{ line }}

        {% if not loop.last %}<br>{% endif %}
    {% endfor %}
</p>
{% endfor %}

<hr />

{% include path + "gloire-pere.html" %}

<p><a id="haut" href="#">Retour en haut</a></p>
{% endblock %}