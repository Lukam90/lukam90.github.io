{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set spath = "prieres/special/" %}

{% set title = "Chapelet des âmes" %}

{% set base_url = "https://boutique.labonnenouvelle.net/chapelets-et-rosaire/" %}
{% set ext_url = base_url + "1073-chapelet-des-ames-du-purgatoire-9502379583487.html" %}

{% block content %}
<p>Il s'agit du {{ mc.link("chapelet des 13 vertus de Notre-Dame", ext_url) }}.</p>

<p>Les {{ mc.link("prières de base", "/prieres/ex-base.html") }} sont listées sur une page dédiée.</p>

<!-- Base -->

{{ mc.anchor("base", "=") }}

<p>{{ mc.checkbox("v_latine", "Version latine", "switchLang()") }}</p>

{% include bpath + "signe-croix.jinja" %}

<hr id="credo" />

{% include bpath + "credo.jinja" %}

{{ mc.anchor("pater") }}

{% include bpath + "notre-pere.jinja" %}

{{ mc.anchor("gloria") }}

{% include bpath + "gloire-pere.jinja" %}

{{ mc.grains("base_trio", ["", "Saints", "St Michel", "Anges gardiens"]) }}

{{ mc.anchor("ave") }}

{% include bpath + "ste-marie.jinja" %}

<!-- Médaille -->

{{ mc.anchor("medaille", "=") }}

{% include spath + "ex-medaille.jinja" %}

<!-- Rondes -->

{{ mc.anchor("niveaux", "=") }}

{{ mc.grains("nv_grains", range(1, 14)) }}

<p id="niveau" class="gras">1. Crainte de Dieu</p>

{% include bpath + "ste-marie.jinja" %}

<hr />

{% include spath + "ex-repos.jinja" %}

{{ mc.grains("nv_trio", range(0, 4)) }}

{{ mc.return_link("niveaux") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}

{{ mc.script("chapelets/ch-ames.js") }}

{% endblock %}