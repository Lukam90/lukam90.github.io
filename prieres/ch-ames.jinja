{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set rpath = "prieres/rosaire/" %}
{% set spath = "prieres/special/" %}

{% set title = "Chapelet des âmes" %}

{% block content %}
<p>Il s'agit du <b>chapelet de Ste Gertrude</b>, basé sur la dévotion du {{ mc.link("rosaire", "/prieres/chapelet.html") }}.</p>

<p>Chaque récitation de la prière des dizaines permet de libérer jusqu'à <b>1000 âmes</b> du purgatoire.</p>

<p>Les {{ mc.link("prières de base", "/prieres/ex-base.html") }} sont listées sur une page dédiée.</p>

<!-- Base -->

{{ mc.anchor("base", "=") }}

<p>{{ mc.checkbox("v_latine", "Version latine", "switchLang()") }}</p>

{% include bpath + "signe-croix.jinja" %}

{% include rpath + "rs-base.jinja" %}

<!-- Rondes -->

{{ mc.anchor("rondes", "=") }}

{% include rpath + "rs-mysteres.jinja" %}

{{ mc.anchor("dz_pater") }}

{% include bpath + "notre-pere.jinja" %}

{{ mc.anchor("dz_priere") }}

{% include spath + "ex-pere-eternel.jinja" %}

{{ mc.grains("dz_grains", range(0, 11)) }}

{{ mc.anchor("dz_coeurs") }}

{% include spath + "ex-coeurs.jinja" %}

{{ mc.anchor("dz_gloria") }}

{% include bpath + "gloire-pere.jinja" %}

{{ mc.return_link("rondes") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}

{{ mc.script("chapelets/ch-mysteres.js") }}
{{ mc.script("chapelets/ch-rosaire.js") }}

{% endblock %}