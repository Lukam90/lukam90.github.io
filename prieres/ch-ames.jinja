{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set rpath = "prieres/rosaire/" %}
{% set spath = "prieres/special/" %}

{% set title = "Chapelet du salut des âmes" %}

{% block content %}
<p>La récitation de ce chapelet permet de libérer jusqu'à <b>5000 âmes</b> sur <b>4 générations</b>.</p>

<p>Le {{ mc.link("/prieres/chapelet.html", "chapelet traditionnel du rosaire") }} reste la dévotion quotidienne de base.</p>

<hr />

<p>{{ mc.checkbox("v_latine", "Version latine", "switchLang()") }}</p>

{% include bpath + "signe-croix.jinja" %}

<!-- Base -->

{{ mc.anchor("base", "=") }}

{% include rpath + "rs-base.jinja" %}

<!-- Rondes -->

{{ mc.anchor("mysteres", "=") }}

{% include rpath + "rs-mysteres.jinja" %}

{% include spath + "ex-pere-eternel.jinja" %}

{{ mc.anchor("ex_coeurs") }}

{% include spath + "ex-coeurs.jinja" %}

{{ mc.grains("dizaine", "dz_grains") }}

{{ mc.return_link("mysteres") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include bpath + "gloire-pere.jinja" %}

{{ mc.grains("ames", "fin_trio") }}

<!-- Réinitialisation -->

{{ mc.anchor("reset", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{% include rpath + "rs-scripts.jinja" %}

{{ mc.script("chapelets/ch-ames.js") }}

{% endblock %}