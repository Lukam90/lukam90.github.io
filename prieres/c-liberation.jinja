{% extends "layouts/prieres.jinja" %}

{% set path = "partials/prieres/" %}
{% set gpath = path + "grains/" %}
{% set lpath = path + "liberation/" %}

{% set title = "C-Liberation" %}

{% block content %}
<h1>Chapelet de libération</h1>

{% include path + "signe-croix.html" %}

<hr />

{% include path + "credo.html" %}

{{ mc.anchor("base_fils") }}

{% include lpath + "lib-fils.html" %}

{{ mc.anchor("base_jesus") }}

{% include lpath + "lib-jesus.html" %}

<p>x 3</p>

<hr id="rondes" />

<p>
    {% for nb in range(1, 6) %}
    <input type="radio" name="rondes" id="n{{ loop.index }}" {% if loop.first %} checked {% endif %} />
    <label for="n{{ loop.index }}">{{ nb }}</label>
    {% endfor %}
</p>

{% include lpath + "lib-fils.html" %}

<p>***</p>

<p>Jésus, <span id="clausule" class="gras">aie pitié de nous</span> !</p>

<p>x 10</p>

<hr />

{% include path + "salut-reine.html" %}

<hr />

{% include path + "signe-croix.html" %}

{{ mc.return_link() }}

<script src="/public/js/ch-liberation.js"></script>
{% endblock %}