{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set rpath = "prieres/rosaire/" %}
{% set spath = "prieres/ames/" %}

{% set title = "Chapelet de libération des âmes" %}

{% block content %}

{{ mc.checkbox("v_latine", "Version latine", "switchLang()") }}

<p>
Il s'agit d'une reprise du {{ mc.link("rosaire", "/prieres/rosaire.html") }} traditionnel,<br>
basée sur la prière révélée par Jésus à <b>Ste Gertrude</b>.<br>
La prière des dizaines permet de libérer jusqu'à <b>1000 âmes</b> à chaque récitation.
</p>

<!-- Base -->

{{ mc.anchor("base", "=") }}

{% include bpath + "signe-croix.jinja" %}

<hr />

{% include rpath + "rs-base.jinja" %}

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

{% include rpath + "rs-mysteres.jinja" %}

{{ mc.anchor("dz_pater") }}

{% include bpath + "notre-pere.jinja" %}

{{ mc.anchor("dz_ames") }}

{% include spath + "ex-pere-eternel.jinja" %}

{{ mc.grains("dz_grains", range(0, 11)) }}

{{ mc.anchor("dz_coeurs") }}

{% include spath + "ex-coeurs.jinja" %}

{{ mc.anchor("dz_gloria") }}

{% include bpath + "gloire-pere.jinja" %}

{{ mc.return_link("mysteres") }}

<!-- Fin -->

<hr />

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}

{{ mc.script("chapelets/ch-rosaire.js") }}
{{ mc.script("chapelets/ch-ames.js") }}

{% endblock %}