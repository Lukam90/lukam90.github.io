{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set rpath = "prieres/rosaire/" %}
{% set spath = "prieres/ames/" %}

{% set title = "Chapelet de libération des âmes" %}

{% block content %}
<p>Le chapelet reprend la structure du {{ mc.link("Saint Rosaire", "/prieres/rosaire.html") }}.</p>

<p>
La prière des dizaines, révélée par Jésus à <b>Sainte Gertrude</b>,<br>
permet de libérer jusqu'à <b>1000 âmes</b> à chaque récitation.</p>

{{ mc.checkbox("v_latine", "Version latine", "switchLang()") }}

<!-- Base -->

{{ mc.anchor("base", "=") }}

{% include bpath + "signe-croix.jinja" %}

{% include rpath + "rs-base.jinja" %}

<!-- Rondes -->

{{ mc.anchor("rondes", "=") }}

{{ mc.grains("dz_rondes", range(1,6), "checkFirst()") }}

{% include bpath + "notre-pere.jinja" %}

{{ mc.anchor("dz_ames") }}

{% include spath + "ex-ames.jinja" %}

{{ mc.grains("dz_grains", range(0, 11)) }}

{{ mc.anchor("dz_coeurs") }}

{% include spath + "ex-coeurs.jinja" %}

{{ mc.anchor("dz_gloria") }}

{% include bpath + "gloire-pere.jinja" %}

{{ mc.return_link("rondes") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}

{{ mc.script("chapelets/ch-ames.js") }}

{% endblock %}