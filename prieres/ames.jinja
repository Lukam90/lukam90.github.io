{% extends "layouts/prieres.jinja" %}

{% set rpath = "prieres/rosaire/" %}
{% set spath = "prieres/ames/" %}

{% set title = "Dizaines de libération des âmes" %}

{% block content %}
<p>Les mystères sont repris du {{ mc.link("Saint Rosaire", "/prieres/rosaire.html") }}.</p>

<p>
La prière des dizaines, révélée par Jésus à <b>Sainte Gertrude</b>,<br>
permet de libérer jusqu'à <b>1000 âmes</b> à chaque récitation.
</p>

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

{% include rpath + "rs-mysteres.jinja" %}

{{ mc.anchor("dz_coeurs") }}

{% include spath + "ex-coeurs.jinja" %}

{{ mc.anchor("dz_ames") }}

{% include spath + "ex-ames.jinja" %}

{{ mc.grains("dz_grains", range(0, 11)) }}

{{ mc.return_link("mysteres") }}

<!-- Scripts -->

{{ mc.script("utils.js") }}

{{ mc.script("chapelets/ch-rosaire.js") }}
{{ mc.script("chapelets/ch-ames.js") }}

{% endblock %}