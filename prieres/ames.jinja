{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set rpath = "prieres/rosaire/" %}

{% set title = "Dizaines de libération des âmes" %}

{% block content %}
<p>La dévotion est complémentaire au {{ mc.link("Saint Rosaire", "/prieres/rosaire.html") }}.</p>

<p>
La simple récitation de la prière des dizaines,<br>
révélée par Jésus à <b>Sainte Gertrude</b>,<br>
permet de libérer jusqu'à <b>1000 âmes</b>.
</p>

{{ mc.checkbox("v_latine", "Version latine", "switchLang()") }}

{{ mc.anchor("base", "=") }}

<!-- Base -->

{% include bpath + "signe-croix.jinja" %}

{% include rpath + "rs-base.jinja" %}

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

{% include rpath + "rs-mysteres.jinja" %}

{% include rpath + "spe-dizaines.jinja" %}

{{ mc.return_link("mysteres") }}

{{ mc.anchor("fin", "=") }}

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}

{{ mc.script("chapelets/ch-rosaire.js") }}
{{ mc.script("chapelets/ch-ames.js") }}

{% endblock %}