{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}

{% set title = "Chapelet de libération" %}

{% block content %}
<p>Ce chapelet est personnel, tout en s'inspirant de la version de base.</p>

<p class="gauche">
Le <b>Credo</b> se récite sur la croix.<br>
Le <b>Notre Père</b> se récite sur les gros grains.<br>
Le <b>verset de St Jean</b> se récite sur les petits grains.<br>
Le <b>Salve Regina</b> se récite à la fin.
</p>

<p>Les {{ mc.link("prières de base", "/prieres/ex-base.html") }} sont listées sur une page dédiée.</p>

<!-- Base -->

{{ mc.anchor("base", "=") }}

<p>{{ mc.checkbox("v_latine", "Version latine", "switchLang()") }}</p>

{% include bpath + "signe-croix.jinja" %}

{{ mc.anchor("credo") }}

{% include bpath + "credo.jinja" %}

<!-- Rondes -->

{{ mc.anchor("rondes", "=") }}

{{ mc.grains("dz_rondes", range(0, 6)) }}

{% include bpath + "notre-pere.jinja" %}

<hr />

<p>"Si Jésus vous libère, vous serez vraiment libres." (Jn 8:36) x <span id="nombre">3</span></p>

{{ mc.return_link("rondes") }}

<!-- Fin -->

{{ mc.anchor("final", "=") }}

{% include bpath + "salut-reine.jinja" %}

<hr />

{% include bpath + "signe-croix.jinja" %}

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("latin.js") }}

{{ mc.script("chapelets/ch-liberation.js") }}

{% endblock %}