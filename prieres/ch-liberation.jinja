{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set rpath = "prieres/rosaire/" %}
{% set spath = "prieres/special/" %}

{% set title = "Chapelet de libération (*)" %}

{% block content %}
<p>Ce <b>chapelet de libération</b> est personnel et basé sur la <b>méthode Ho'oponopono</b>.</p>

<p>La <b>prière de transmutation</b> se récite sur la croix.</p>

<hr />

{% include bpath + "signe-croix.jinja" %}

<!-- Base -->

{{ mc.anchor("croix", "=") }}

<p>
Je demande la transmutation divine de toutes ces mémoires négatives en moi<br />
et liées à <input type="text" id="intention" placeholder="ma situation actuelle" /> 
en amour inconditionnel.
</p>

<!-- Rondes -->

{{ mc.anchor("rondes", "=") }}

{{ mc.grains("cinq", "sel_rondes") }}

<p>Je demande à être libéré dans l'amour.</p>

<hr />

<p>Désolé. Pardon. Merci. Je t'aime. (x 3, x 10)</p>

{{ mc.return_link() }}

{% endblock %}