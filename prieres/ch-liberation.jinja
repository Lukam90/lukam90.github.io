{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set spath = "prieres/special/" %}

{% set title = "Chapelet de libération" %}

{% block content %}
<p>
Le chapelet est personnel et s'inspire de la <b>méthode Ho'oponopono</b>.<br>
La <b>prière de transmutation</b> se récite sur la <b>croix</b> et les <b>gros grains</b>.
</p>

{{ mc.anchor("croix", "=") }}

{% include bpath + "signe-croix.jinja" %}

{% include spath + "ex-hopono.jinja" %}

<hr />

<p>
Je t'aime.<br>
Je suis désolé.<br>
Je te demande pardon.<br>
Je te remercie.<br>
(x 3, 10)
</p>

{{ mc.grains("cinq", "dz_rondes") }}

{% endblock %}