{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}
{% set spath = "prieres/special/" %}

{% set title = "Chapelet de libération" %}

{% block content %}
<p>
Le chapelet est personnel et s'inspire de la <b>méthode Ho'oponopono</b>.<br>
La <b>prière de transmutation</b> se récite sur la <b>croix</b>.
</p>

{{ mc.anchor("croix", "=") }}

{% include bpath + "signe-croix.jinja" %}

<p>
Je demande la transmutation divine de toutes ces mémoires négatives en moi<br>
et liées à <input type="text" id="txt_intention" placeholder="ma situation actuelle" />
en amour inconditionnel.
</p>

<hr />

<p>Désolé. Pardon. Merci. Je t'aime. (x 3)</p>

{{ mc.anchor("rondes", "=") }}

<p>Ronde {{ mc.select("sel_rondes") }}</p>

<p>Je demande à être libéré dans l'amour.</p>

<hr />

<p>Désolé. Pardon. Merci. Je t'aime.</p>

{{ mc.grains("dizaine", "dz_grains") }}

<!-- Scripts -->

{{ mc.script("utils.js") }}
{{ mc.script("reset.js") }}

{% endblock %}