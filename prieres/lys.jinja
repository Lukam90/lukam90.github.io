{% extends "layouts/prieres.jinja" %}

{% set rpath = "prieres/rosaire/" %}
{% set spath = "prieres/saints/" %}

{% set title = "Chapelet des lys de St Joseph" %}

{% block content %}
<p>Les {{ mc.link("prières de base", "/prieres/ex-base.html") }} sont listées sur une page dédiée.</p>

{{ mc.anchor("base", "=") }}

<!-- Base -->

<p>(Signe de croix)</p>

{% include rpath + "lys-base.jinja" %}

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

{% include rpath + "lys-mysteres.jinja" %}

<hr />

<p class="gras">Notre Père</p>

{% include spath + "st-joseph.jinja" %}

{{ mc.grains("dz_grains", range(0, 11)) }}

<p class="gras">Gloire au Père</p>

<p class="gras">(Prière de Fatima)</p>

{{ mc.return_link("mysteres") }}

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

<p>(Signe de croix)</p>

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}

{{ mc.script("chapelets/ch-lys.js") }}

{% endblock %}