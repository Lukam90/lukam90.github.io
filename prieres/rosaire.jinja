{% extends "layouts/prieres.jinja" %}

{% set bpath = "prieres/base/" %}

{% set title = "Chapelet du rosaire" %}

{% block content %}
<p>Les {{ mc.link("prières de base", "/prieres/ex-base.html") }} sont listées sur une page dédiée.</p>

<p>Je recommande l'application {{ mc.link("Rosario", "https://rosario.app/") }} pour la méditation des <b>mystères</b>.</p>

<!-- Base -->

{{ mc.anchor("base", "=") }}

<p>(Signe de croix)</p>

<p>{{ mc.checkbox("b_credo", "Credo") }}</p>

<p>{{ mc.checkbox("b_pater", "Notre Père") }}</p>

<p>
{{ mc.checkbox("b_ave", "3 x Je vous salue Marie") }}<br>
(foi, espérance, charité)
</p>

<p>{{ mc.checkbox("b_gloria", "Gloire au Père") }}</p>

<!-- Mystères -->

{{ mc.anchor("mysteres", "=") }}

<p>
    Mystères

    <select id="sel_type" onchange="selectType();">
        <option>joyeux</option>
        <option>lumineux</option>
        <option>douloureux</option>
        <option>glorieux</option>
    </select>
</p>

<ul class="priere gauche">
    <li>{{ mc.radio_btn("m1", "mysteres", "1. L'annonciation") }} </li>
    <li>{{ mc.radio_btn("m2", "mysteres", "2. La visitation") }} </li>
    <li>{{ mc.radio_btn("m3", "mysteres", "3. la naissance de Jésus") }} </li>
    <li>{{ mc.radio_btn("m4", "mysteres", "4. la présentation de Jésus au temple de Jérusalem") }} </li>
    <li>{{ mc.radio_btn("m5", "mysteres", "5. le recouvrement de Jésus au temple de Jérusalem") }} </li>
</ul>

<hr />

<p>{{ mc.checkbox("dz_pater", "Notre Père") }}</p>

<p>10 x Je vous salue Marie</p>

{{ mc.grains("dz_grains", range(0, 11)) }}

<p>{{ mc.checkbox("dz_gloria", "Gloire Père") }}</p>

<p>{{ mc.checkbox("dz_fatima", "(Prière de Fatima)") }}</p>

<!-- Fin -->

{{ mc.anchor("fin", "=") }}

<p>(Signe de croix)</p>

{{ mc.return_link(label = "Recommencer", reset = True) }}

<!-- Scripts -->

{{ mc.script("utils.js") }}

{{ mc.script("chapelets/ch-rosaire.js") }}

{% endblock %}